# Telegram DL Guard — Secrets
# Copy to .env and fill in. Never commit this file.

# Get from https://my.telegram.org/apps
API_ID=
API_HASH=

# Session string (auto-filled after first login)
SESSION_STRING=

# Low-end safe defaults
TARGET_GROUPS=
STORAGE_GROUP_ID=
DOWNLOAD_DIR=./downloads
PROCESSING_MODE=download
MEDIA_TYPES=photo,video
QUEUE_SIZE=1
UPLOAD_ENABLED=false
UPLOAD_WORKERS=1
DEDUP_ENABLED=true
DEDUP_METHOD=size
HISTORY_ENABLED=false
HISTORY_MAX_MESSAGES=500
WEB_AUTO_OPEN=false
